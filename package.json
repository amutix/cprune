{
  "name": "cprune-pi-extension",
  "version": "0.4.3",
  "description": "Pi extension that trims noisy agent context and reports deterministic off/safe/full savings.",
  "license": "MIT",
  "type": "module",
  "pi": {
    "extensions": [
      "src/cprune.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "rm -rf .tmp-test && tsc -p tsconfig.test.json && node --test .tmp-test/tests/*.js && rm -rf .tmp-test"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@types/node": "latest",
    "typebox": "latest",
    "typescript": "latest"
  }
}
